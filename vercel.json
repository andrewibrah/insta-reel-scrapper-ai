{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/process.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/process", "destination": "/api/process" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
