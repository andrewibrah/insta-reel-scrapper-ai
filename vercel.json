{
  "buildCommand": "node scripts/setup-ytdlp.mjs && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/process.ts": {
      "maxDuration": 60,
      "includeFiles": "bin/**"
    }
  },
  "rewrites": [
    { "source": "/api/process", "destination": "/api/process" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
